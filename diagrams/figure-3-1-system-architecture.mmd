---
title: Figure 3.1 — DentyHub High-Level System Architecture
config:
  theme: default
  themeVariables:
    fontFamily: "Cambria, Georgia, serif"
    fontSize: "15px"
    primaryColor: "#E7EEF2"
    primaryTextColor: "#0F172A"
    primaryBorderColor: "#0F172A"
    lineColor: "#1F2937"
---

flowchart LR

    %% ============ CLIENT TIER ============
    subgraph Client["<b>Client Tier</b> &mdash; User Device"]
        direction TB
        B["<b>Browser</b><br/><br/>Patient &middot; Doctor<br/>Supervisor &middot; Admin<br/><br/>Desktop &middot; Android (360px+)<br/>iOS Safari &middot; Chrome &middot; Edge"]
    end

    %% ============ PRESENTATION TIER ============
    subgraph Presentation["<b>Presentation Tier</b> &mdash; Next.js 16 &middot; React 19 &middot; Tailwind v4 &middot; port 3000"]
        direction TB
        N1["<b>App Router Pages</b><br/>(auth) &middot; patient &middot; doctor<br/>supervisor &middot; admin"]
        N2["<b>Feature Modules</b><br/>arcade &middot; streak &middot; cases<br/>chat &middot; profile &middot; settings"]
        N3["<b>Cross-Cutting</b><br/>Language Provider (EN + AR, RTL)<br/>Theme Provider (light + dark)<br/>Auth Store + authHeaders()"]
    end

    %% ============ APPLICATION TIER ============
    subgraph Application["<b>Application Tier</b> &mdash; NestJS 11 &middot; Node 20+ &middot; port 4000"]
        direction TB
        A1["<b>11 Controllers &middot; 119 REST endpoints</b><br/>auth &middot; appointments &middot; arcade<br/>cases &middot; chat &middot; game &middot; notifications<br/>profiles &middot; smile-streak &middot; supervisor"]
        A2["<b>Guards + Pipes</b><br/>JwtAuthGuard &middot; AdminGuard<br/>class-validator DTOs<br/>Role-data scoping"]
        A3["<b>Domain Services</b><br/>Conflict detection &middot; supervisor decision<br/>Arcade unlock logic &middot; streak rollup<br/>Notification + chat dispatch"]
    end

    %% ============ DATA TIER ============
    subgraph Data["<b>Data Tier</b>"]
        direction TB
        P["<b>Prisma 5.22</b><br/>Generated TypeScript client<br/>$transaction for atomic writes<br/>Append-only migrations"]
        D[("<b>PostgreSQL 16</b><br/>port 5433<br/>41 models &middot; 18 enums<br/>FK referential integrity")]
    end

    %% ============ EXTERNAL ============
    subgraph External["<b>Operations</b>"]
        direction TB
        ENV["<b>Environment</b><br/>JWT_SECRET &middot; DATABASE_URL<br/>DENTYHUB_WEB_ORIGIN<br/>(.env / Fly + Vercel secrets)"]
        CRON["<b>Background Jobs</b><br/>Slot auto-purge (>24h stale)<br/>Daily streak rollover<br/>Arcade leaderboard cache"]
    end

    %% ============ FLOWS ============
    B  -- "HTTPS &middot; HTML + JS bundle<br/>JWT in localStorage" --> N1
    N1 --> N2
    N1 --> N3
    N3 -- "REST / JSON<br/>Authorization: Bearer JWT" --> A1
    A1 -- "@UseGuards" --> A2
    A1 --> A3
    A3 -- "PrismaService<br/>injection" --> P
    P  -- "TCP 5433<br/>parameterised SQL" --> D
    ENV -. "loads at boot" .-> A1
    CRON -. "scheduled invocation" .-> A3

    %% ============ STYLING ============
    classDef clientTier     fill:#FEF3C7,stroke:#B45309,stroke-width:2px,color:#0F172A
    classDef frontendTier   fill:#DBEAFE,stroke:#1E3A8A,stroke-width:2px,color:#0F172A
    classDef backendTier    fill:#D1FAE5,stroke:#065F46,stroke-width:2px,color:#0F172A
    classDef dataTier       fill:#EDE9FE,stroke:#5B21B6,stroke-width:2px,color:#0F172A
    classDef opsTier        fill:#F3F4F6,stroke:#374151,stroke-width:1.5px,color:#0F172A,stroke-dasharray:5 5

    class B clientTier
    class N1,N2,N3 frontendTier
    class A1,A2,A3 backendTier
    class P,D dataTier
    class ENV,CRON opsTier
