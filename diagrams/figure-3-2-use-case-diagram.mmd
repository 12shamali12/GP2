flowchart LR

    %% ============ ACTORS (left column) ============
    PAT(("👤<br/><b>Patient</b>"))
    DOC(("👤<br/><b>Doctor</b><br/>(student)"))
    SUP(("👤<br/><b>Supervisor</b>"))
    ADM(("👤<br/><b>Admin</b>"))

    %% ============ SYSTEM BOUNDARY ============
    subgraph System["<b>DentyHub System</b>"]
        %% ---- Patient use cases ----
        UC_P1(["Register +<br/>Log in"])
        UC_P2(["Browse +<br/>Book Slot"])
        UC_P3(["Track Appointment<br/>+ View Report"])
        UC_P4(["Daily Smile<br/>Check-in + Badges"])
        UC_P5(["Play Arcade<br/>(6 games)"])
        UC_P6(["Daily Trivia<br/>Quiz"])
        UC_P7(["Rate +<br/>Report Misconduct"])

        %% ---- Doctor use cases ----
        UC_D1(["Submit<br/>Credentials"])
        UC_D2(["Manage<br/>Case Queue"])
        UC_D3(["Submit<br/>Case Report"])
        UC_D4(["Respond to<br/>Supervisor Decision"])
        UC_D5(["Track Graduation<br/>Progress"])
        UC_D6(["Take Exams +<br/>Clinic Tasks"])
        UC_D7(["Set Availability<br/>+ Schedule"])

        %% ---- Supervisor use cases ----
        UC_S1(["Submit<br/>Credentials"])
        UC_S2(["Review Reports<br/>(Approve / Edit / Redo)"])
        UC_S3(["Grade Exams +<br/>Tasks"])
        UC_S4(["Manage Doctors<br/>(Freeze + Group)"])
        UC_S5(["Post to<br/>Group Feed"])

        %% ---- Admin use cases ----
        UC_A1(["Vet<br/>Credentials"])
        UC_A2(["Manage User<br/>Directory"])
        UC_A3(["Manage Clinics<br/>+ Shifts + Cases"])
        UC_A4(["Manage Semesters +<br/>Cohort Progression"])
        UC_A5(["Manage Rotation<br/>Plans"])
        UC_A6(["Group + Partner<br/>Moderation"])
        UC_A7(["Review User<br/>Reports"])

        %% ---- Cross-cutting use cases ----
        UC_X1(["Receive<br/>Notifications"])
        UC_X2(["Chat 1-to-1"])
        UC_X3(["Switch Language<br/>EN ↔ AR"])
        UC_X4(["Update Profile +<br/>Change Password"])
    end

