# Copy this file to backend/.env and fill in real values.
# Never commit backend/.env.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME"

# HTTP
PORT=3000

# JWT — generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Seeded admin account (created on first boot if it does not exist).
# Change these before any non-local deployment.
ADMIN_USERNAME="prof.shamali"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_EMAIL="admin@example.com"
ADMIN_PHONE="0700000000"
ADMIN_NAME="Admin"
