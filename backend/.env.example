# DentyHub backend — environment template.
#
# LOCAL DEV: copy this file to backend/.env, fill in real values, run
# `pnpm prisma migrate dev` + `pnpm dev`.
#
# PRODUCTION (Fly.io): set each value below as a Fly secret:
#   fly secrets set NAME=value NAME2=value2 ...
# Fly secrets are encrypted and injected as env vars at boot. Do NOT put
# secrets in fly.toml — that file lives in git.

# ---- Database -------------------------------------------------------------
# Local: postgresql://USER:PASS@localhost:5433/mydb
# Prod (Neon): copy the "pooled" connection string from the Neon console
#              (looks like postgresql://...neon.tech/dbname?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME"

# ---- Server ---------------------------------------------------------------
# Local: any free port. Prod: 3000 (matches Dockerfile EXPOSE + fly.toml).
PORT=3000

# ---- CORS allowlist -------------------------------------------------------
# Comma-separated list of origins permitted to call the API. REQUIRED in
# production — if unset, the server rejects every browser request.
# Local: leave empty (server falls back to permissive for dev only).
# Prod: set to your Vercel URL(s), e.g.
#   CORS_ORIGIN="https://dentyhub.vercel.app,https://dentyhub-git-main-shamali.vercel.app"
CORS_ORIGIN=""

# ---- Auth -----------------------------------------------------------------
# JWT_SECRET: generate a new 64-byte random string for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# DO NOT reuse the dev secret in production.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- Seed admin account ---------------------------------------------------
# Upserted by backend/src/seed.service.ts on every boot. Changing these and
# restarting the backend updates the live admin's email / password / phone
# (the row is matched by username). For the deployed app these are set as
# Fly secrets, not via this file.
ADMIN_USERNAME="prof.shamali"
ADMIN_PASSWORD="Aa123456@"
ADMIN_EMAIL="omar.sh.880.oa@gmail.com"
ADMIN_PHONE="0795658040"
ADMIN_NAME="Admin"
SUPERVISOR_EMAIL="omar.sh.880.oa@gmail.com"
